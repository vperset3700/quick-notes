FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements-callback.txt /app/requirements-callback.txt
RUN pip install --no-cache-dir -r /app/requirements-callback.txt

COPY . /app

EXPOSE 8000
CMD ["uvicorn", "callback_api.main:app", "--host", "0.0.0.0", "--port", "8000"]
